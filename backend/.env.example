PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/unimate
ADMIN_API_KEY=change-me-to-a-strong-secret
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin@fpt.edu.vn
ADMIN_SEED_EMAIL=admin@fpt.edu.vn
ADMIN_SEED_PASSWORD=Admin@123456
ADMIN_SEED_NAME=Unimate Admin
CLIENT_ORIGIN=http://localhost:5173
# Thêm URL ngrok frontend (nếu dùng tunnel:web), phân cách bằng dấu phẩy
# CLIENT_ORIGINS=https://xxxx.ngrok-free.dev

APP_NAME=ChatBox Server
APP_ENV=dev
PUBLIC_BASE_URL=http://localhost:5000
CORS_ALLOW_ORIGINS=*

LLM_PROVIDER=openai
STT_PROVIDER=fpt
TTS_PROVIDER=fpt
CHAT_STORE_PROVIDER=mongo

AUDIO_STORAGE_DIR=storage/audio
VOICE_UPLOAD_DIR=storage/uploads

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1
OPENAI_VECTOR_STORE_ID=
OPENAI_VECTOR_STORE_ID_FILE=storage/openai_vector_store_id.txt
OPENAI_VECTOR_STORE_NAME=fpt-university-regulations

FPT_ASR_URL=https://api.fpt.ai/hmi/asr/general
FPT_ASR_API_KEY=your_fpt_api_key
FPT_TTS_URL=https://api.fpt.ai/hmi/tts/v5
FPT_TTS_API_KEY=your_fpt_api_key
FPT_TTS_VOICE=banmai
FPT_TTS_SPEED=
FPT_TTS_POLL_ATTEMPTS=90
FPT_TTS_POLL_INTERVAL_SECONDS=1.0

# Ngrok — lấy token tại https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Email gửi góp ý (Gmail: bật App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_RECEIVER_EMAIL=unimate@fpt.edu.vn
